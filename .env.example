# ---- Supabase ----
# Project URL + anon (publishable) key — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only (optional; used by public share pages in a later phase)
SUPABASE_SERVICE_ROLE_KEY=

# ---- OpenRouter (LLM gateway + built-in web search) ----
# Powers both summarization and source discovery (the `web` plugin).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Background source-discovery / tagging model (optional override).
# The user-facing article models per tier live in src/lib/ai/model-catalog.ts.
OPENROUTER_MODEL_CATEGORIZE=

# ---- Jina Reader (used only for pasted-URL summaries; works without a key) ----
JINA_API_KEY=

# ---- Hume Octave TTS (optional; enables Max "Audio Overview" narration) ----
# Without it, audio is hidden. Also create a private Supabase Storage bucket
# named "audio" (schema.sql does this) and run the audio_overviews table migration.
HUME_API_KEY=
# Optional: override the narrator persona (natural-language voice description).
HUME_VOICE_DESCRIPTION=

# ---- Upstash Redis (cache, rate limiting, daily query budget) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Stripe (payments) ----
# Secret key (test: sk_test_… / live: sk_live_…) — server-only, never NEXT_PUBLIC.
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_…) — from the Stripe CLI locally, or the
# dashboard webhook endpoint in prod.
STRIPE_WEBHOOK_SECRET=
# Recurring monthly Price ids for each paid tier (price_…).
STRIPE_PRICE_PRO=
STRIPE_PRICE_MAX=

# ---- App ----
# Public site URL, used for OAuth redirects (e.g. http://localhost:3000 in dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional: address for the "Suggest a correction" link on source ratings.
# When unset, the link is hidden.
NEXT_PUBLIC_FEEDBACK_EMAIL=
